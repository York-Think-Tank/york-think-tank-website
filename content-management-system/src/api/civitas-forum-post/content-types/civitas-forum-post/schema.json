{
  "kind": "collectionType",
  "collectionName": "civitas_forum_posts",
  "info": {
    "singularName": "civitas-forum-post",
    "pluralName": "civitas-forum-posts",
    "displayName": "Civitas Forum Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "contributors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::ytt-contributor.ytt-contributor"
    }
  }
}
