{
  "kind": "collectionType",
  "collectionName": "ytt_events",
  "info": {
    "singularName": "ytt-event",
    "pluralName": "ytt-events",
    "displayName": "YTT Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "event_date": {
      "type": "datetime",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "signup_link": {
      "type": "string"
    }
  }
}
